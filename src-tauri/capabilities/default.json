{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    "dialog:default",
    "dialog:allow-open",
    "fs:default",
    "updater:default",
    "process:default",
    "process:allow-restart",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPDATA/games/**" },
        { "path": "$APPDATA/audio/**" },
        { "path": "$HOME/Library/Application Support/bcgAgent/**" }
      ]
    }
  ]
}
