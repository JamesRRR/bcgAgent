{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "bcgAgent",
  "version": "0.2.1",
  "identifier": "com.bcgagent.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "攀达桌游",
        "width": 1100,
        "height": 750,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/games/**",
          "$APPDATA/audio/**",
          "$HOME/Library/Application Support/bcgAgent/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "-",
      "providerShortName": null,
      "infoPlist": "Info.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYyOUY2Rjg0MEFGNUQ4MjUKUldRbDJQVUtoRytmWXUxbHdEN0RsNDhDdzFOZnYrS2c2MUh4UGtULzZVQWhFL3VDRHB4WG1wazUK",
      "endpoints": [
        "https://github.com/JamesRRR/bcgAgent/releases/latest/download/latest.json"
      ]
    }
  }
}
